{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_SERVER_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "BETTER_AUTH_URL",
    "CORS_ORIGIN",
    "WEB_DOMAIN",
    "SERVER_DOMAIN",
    "STAGE"
  ],
  "globalPassThroughEnv": [
    "ALCHEMY_PASSWORD",
    "ALCHEMY_STATE_TOKEN",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_EMAIL",
    "BETTER_AUTH_SECRET",
    "TURNSTILE_SECRET",
    "TURNSTILE_ENABLED",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "deploy": {
      "cache": false
    },
    "deploy:testing": {
      "cache": false
    },
    "deploy:prod": {
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
